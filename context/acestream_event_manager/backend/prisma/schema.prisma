generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model EventSession {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String?
  regexFilter String   @default(".*")
  timeoutMs   Int      @default(30000)
  staggerMs   Int      @default(200)
  probeIntervalMs Int  @default(300000)
  isActive    Boolean  @default(true)
  channel     Channel? @relation(fields: [channelId], references: [id])
  channelId   Int?     // Dispatcharr Channel ID
}

model Channel {
  id            Int            @id // Matches Dispatcharr ID
  name                String
  channelNumber       Float?
  iconUrl             String?
  currentProgramTitle String?
  currentProgramStart DateTime?
  currentProgramEnd   DateTime?
  sessions      EventSession[]
  streams       Stream[]
}

model Stream {
  id              String         @id // AceStream ID (Infohash)
  channelId       Int
  channel         Channel        @relation(fields: [channelId], references: [id])
  url             String
  name            String?
  m3u_account     String?        // m3u source / account
  
  // Static quality metrics from Dispatcharr/Parsing
  width           Int?
  height          Int?
  fps             Float?
  bitrate         Int?
  
  // State
  isQuarantined   Boolean        @default(false)
  quarantinedAt   DateTime?
  lastCheckedAt   DateTime?
  
  healthHistory   StreamHealth[]
}

model StreamHealth {
  id        Int      @id @default(autoincrement())
  streamId  String
  stream    Stream   @relation(fields: [streamId], references: [id])
  timestamp DateTime @default(now())
  
  speed     Float?   // From Orchestrator/FFmpeg
  peers     Int?     // From Orchestrator
  
  failed    Boolean  @default(false)
}

model Preset {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  channelId   Int
  regexFilter String   @default(".*")
  timeoutMs   Int      @default(30000)
  staggerMs   Int      @default(200)
}
